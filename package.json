{
  "name": "openclaw-scheduler",
  "version": "0.1.0",
  "description": "SQLite-backed job scheduler, workflow engine, and inter-agent message router for OpenClaw. Replaces built-in cron and heartbeat with full run history, workflow chains, retry logic, shell jobs, approval gates, and backup support.",
  "type": "module",
  "main": "dispatcher.js",
  "bin": {
    "openclaw-scheduler": "bin/openclaw-scheduler.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node dispatcher.js",
    "migrate": "node migrate.js",
    "test": "SCHEDULER_DB=:memory: node test.js",
    "lint": "eslint . --max-warnings=0",
    "coverage": "SCHEDULER_DB=:memory: node scripts/coverage.mjs"
  },
  "files": [
    "bin",
    "dispatch",
    "scripts",
    "*.js",
    "*.mjs",
    "*.sql",
    "*.plist",
    "*.service",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "INSTALL*.md",
    "UNINSTALL.md",
    "BEST-PRACTICES.md",
    "IMPLEMENTATION_SPEC.md",
    "test.js"
  ],
  "keywords": [
    "openclaw",
    "scheduler",
    "cron",
    "workflow",
    "sqlite",
    "agent",
    "automation"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amittell/openclaw-scheduler.git"
  },
  "bugs": {
    "url": "https://github.com/amittell/openclaw-scheduler/issues"
  },
  "homepage": "https://github.com/amittell/openclaw-scheduler#readme",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "croner": "^10.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.2",
    "globals": "^17.4.0"
  }
}
